generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User model definition
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suppliers Supplier[]
}

// Supplier model
model Supplier {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  email        String   @unique
  name         String
  status       String
  active       Boolean @default(true)
  isRegistered Boolean  @default(false)
  creatorId    Int
  searchString String
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id])
  rfps RFPSupplier[]
}

// rfp model
model RFP {
  id Int @id @default(autoincrement())
  code String @unique
  active Boolean @default(true)
  status String
  searchString String
  subject String
  fieldResponses Json @default(dbgenerated("'{}'"))

  userId Int
  templateId Int

  template Json @default(dbgenerated("'{}'"))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  lineItems LineItem[]
  suppliers RFPSupplier[]
}

//rfp line items 
model LineItem {
  id Int @id @default(autoincrement())
  sno Int
  status String
  fieldResponses Json @default(dbgenerated("'{}'"))
  
  quantity Int
  price Decimal @db.Decimal(12,2)

  productId Int
  rfpId Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfp RFP @relation(fields: [rfpId], references:[id])
}

model Template {
  id Int @id @default(autoincrement())
  status String
  parentTemplateId Int?
  version Int
  active Boolean @default(true)
  label String
  config Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections Section[]
}

model Section {
  id Int @id @default(autoincrement())
  label String
  templateId Int
  active Boolean @default(true)
  sectiontype String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template Template @relation(fields: [templateId], references: [id])
  fields   Field[]
}

model Field {
  id Int @id @default(autoincrement())
  label String
  sectionId Int
  active Boolean @default(true)
  systemKey String
  mandatory Boolean @default(false)
  type String
  sectiontype String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id])
}

model RFPSupplier {
  id          Int      @id @default(autoincrement())
  rfpId       Int
  supplierId  Int
  status      String @default("invited")
  invitedAt   DateTime @default(now())
  respondedAt DateTime?

  rfp       RFP      @relation(fields: [rfpId], references: [id])
  supplier  Supplier @relation(fields: [supplierId], references: [id])

  @@unique([rfpId, supplierId])
  @@index([supplierId])
  @@index([rfpId])
}

model SupplierLineItemQuote {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  lineItemId  Int
  price       Decimal  @db.Decimal(12,2)
  remarks     String?
  submittedAt DateTime @default(now())

  fieldResponses Json @default(dbgenerated("'{}'"))

  supplier Supplier @relation(fields: [supplierId], references: [id])
  lineItem LineItem @relation(fields: [lineItemId], references: [id])

  @@unique([supplierId, lineItemId])
}
